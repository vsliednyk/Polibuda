<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--Glowne okno napisane w javaFX przy uzyciu SceneBuildera-->

<VBox prefHeight="650.0" prefWidth="950.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="kryptografia.MainController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <TitledPane collapsible="false" text="Klucz">
        <VBox spacing="15.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>

            <HBox spacing="30.0">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Wartość I klucza" />
                    <TextField fx:id="key1Field" />
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Wartość II klucza" />
                    <TextField fx:id="key2Field" />
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Wartość III klucza" />
                    <TextField fx:id="key3Field" />
                </VBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <Label text="Wygeneruj wartość klucza" />
                <Button fx:id="generateKeysBtn" text="Generuj klucze" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Wczytaj klucze z pliku" />
                <TextField fx:id="loadKeyPathField" prefWidth="150.0" promptText="Nazwa pliku kluczy" />
                <Button fx:id="loadKeyBtn" text="Wczytaj" />

                <Region HBox.hgrow="ALWAYS" /> <Label text="Zapisz klucze do pliku" />
                <TextField fx:id="saveKeyPathField" prefWidth="150.0" promptText="Nazwa pliku kluczy" />
                <Button fx:id="saveKeyBtn" text="Zapisz" />
            </HBox>
        </VBox>
    </TitledPane>

    <TitledPane collapsible="false" text="Szyfrowanie / Deszyfrowanie" VBox.vgrow="ALWAYS">
        <HBox spacing="20.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>

            <VBox maxWidth="1.7976931348623157E308" spacing="10.0" HBox.hgrow="ALWAYS">
                <Label text="Otwórz plik zawierający tekst jawny" />
            <HBox prefHeight="15.0" prefWidth="369.0">
               <children>
                  <Label prefHeight="17.0" prefWidth="65.0" text="Status : " />
                  <Label fx:id="plainStatusTitle" prefHeight="17.0" prefWidth="327.0" text="Nic nie wprowadzono">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
                <HBox spacing="5.0">
                    <TextField fx:id="openPlainPathField" promptText="Nazwa pliku z tekstem jawnym" HBox.hgrow="ALWAYS" />
                    <Button fx:id="openPlainBtn" text="Otwórz" />
                </HBox>

                <TextArea fx:id="plainTextArea" promptText="Tu podaj tekst jawny" wrapText="true" VBox.vgrow="ALWAYS" />

                <Label text="Zapisz plik zawierający tekst jawny" />
                <HBox spacing="5.0">
                    <TextField fx:id="savePlainPathField" promptText="Nazwa pliku z tekstem jawnym" HBox.hgrow="ALWAYS" />
                    <Button fx:id="savePlainBtn" text="Zapisz" />
                </HBox>
            </VBox>

            <VBox alignment="CENTER" minWidth="130.0" spacing="20.0">
                <Button fx:id="encryptBtn" prefWidth="110.0" text="Szyfruj -&gt;" />
                <Button fx:id="decryptBtn" prefWidth="110.0" text="&lt;- Deszyfruj" />

                <VBox alignment="CENTER_LEFT" maxWidth="80.0" spacing="10.0">
                    <fx:define>
                        <ToggleGroup fx:id="modeToggleGroup" />
                    </fx:define>
                    <RadioButton fx:id="fileModeRadio" selected="true" text="Plik">
                  <toggleGroup>
                     <ToggleGroup fx:id="modeToggleGroup" />
                  </toggleGroup></RadioButton>
                    <RadioButton fx:id="windowModeRadio" text="Okno" toggleGroup="$modeToggleGroup" />
                </VBox>
            </VBox>

            <VBox maxWidth="1.7976931348623157E308" spacing="10.0" HBox.hgrow="ALWAYS">
                <Label text="Otwórz plik zawierający szyfrogram" />
            <HBox prefHeight="15.0" prefWidth="369.0">
               <children>
                  <Label prefHeight="17.0" prefWidth="61.0" text="Status : " />
                  <Label fx:id="cipherStatusTitle" prefHeight="17.0" prefWidth="327.0" text="Nic nie wprowadzono">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
                <HBox spacing="5.0">
                    <TextField fx:id="openCipherPathField" promptText="Nazwa pliku z szyfrogramem" HBox.hgrow="ALWAYS" />
                    <Button fx:id="openCipherBtn" text="Otwórz" />
                </HBox>

                <TextArea fx:id="cipherTextArea" promptText="Tu podaj szyfrogram" wrapText="true" VBox.vgrow="ALWAYS" />

                <Label text="Zapisz plik zawierający szyfrogram" />
                <HBox spacing="5.0">
                    <TextField fx:id="saveCipherPathField" promptText="Nazwa pliku z szyfrogramem" HBox.hgrow="ALWAYS" />
                    <Button fx:id="saveCipherBtn" text="Zapisz" />
                </HBox>
            </VBox>

        </HBox>
    </TitledPane>
</VBox>
